[
    {
        "term": "魄",
        "category": "Racism",
        "definition": "'魄'是'白鬼'的拼字，指白色的鬼，对白人群体的侮辱性称呼。",
        "targets": "白色人种"
    },
    {
        "term": "墨人",
        "category": "Racism",
        "definition": "'墨人'代指'黑人'，常用于代指黑人群体，含贬义。",
        "targets": "黑色人种"
    },
    {
        "term": "白叠",
        "category": "Racism",
        "definition": "'白叠'是'白爹'的中文谐音，暗示对某种过度崇拜或盲目追随白人群体的现象，常含贬义。",
        "targets": "白色人种"
    },
    {
        "term": "小仙女",
        "category": "Sexism",
        "definition": "在某些情况下被用来指代那些自私自利、双标、让人厌恶的女性。",
        "targets": "女性群体"
    },
    {
        "term": "绿茶",
        "category": "Sexism",
        "definition": "网络用语，用于形容那些在外表上显得清纯、无害，但内心却可能心机深沉、善于利用他人（特别是男性）以达到自己目的的女性。",
        "targets": "女性群体"
    },
    {
        "term": "龟男",
        "category": "Sexism",
        "definition": "形容那些没有自尊、愿意为女性付出一切（哪怕得不到回报）、维护女性特权的男性。",
        "targets": "男性群体"
    },
    {
        "term": "井盖",
        "category": "Xenophobia",
        "definition": "常与'河南人一起使用'，暗示河南人素质低、道德水平差。",
        "targets": "河南人群体"
    },
    {
        "term": "偷国",
        "category": "Xenophobia",
        "definition": "对韩国人的侮辱性用词，来自韩国申遗争议引起的中韩文化纠纷。",
        "targets": "韩国群体"
    },
    {
        "term": "硬盘人",
        "category": "Xenophobia",
        "definition": "意旨外地人，流行于上海人较多之网络，是上海网民对外地人的蔑称。起源于汉语拼音：Wai Di Ren，缩写为WD人，后因网络关键字过滤，改为硬盘人（因WD为硬盘厂商西部数据的缩写）。",
        "targets": "外地人群体"
    },
    {
        "term": "通信录",
        "category": "Heterosexism",
        "definition": "对同性恋群体的简称，常含贬义。",
        "targets": "同性恋群体"
    },
    {
        "term": "玻璃",
        "category": "Heterosexism",
        "definition": "民国六、七十年代台湾社会对男同性恋社群的代称，而玻璃则为男同性恋者的代称。",
        "targets": "男同性恋群体"
    },
    {
        "term": "龙阳之好",
        "category": "Heterosexism",
        "definition": "典故出自《战国策·魏策》中魏王与龙阳君的一段记载，常用于代指男同性恋群体。",
        "targets": "男同性恋群体"
    },
    {
        "term": "猪精",
