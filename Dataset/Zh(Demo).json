        "definition": "指北方游牧民族，如“蒙古鞑子”、“满洲鞑子”。",
        "targets": "北方游牧民族"
    },
    {
        "term": "包头佬",
        "category": "Ethnicism",
        "definition": "马来西亚华裔藉以当地巫裔女性或锡克人裹头巾文化作为对该族的蔑称。",
        "targets": "巫裔及锡克人群体"
    },
    {
        "term": "脑残",
        "category": "Ableism",
        "definition": "现代网络侮辱语，将脑部损伤或发育障碍作为智力低下的隐喻，强化'生理缺陷=思维缺陷'的偏见",
        "targets": "脑部损伤或发育障碍群体"
    },
    {
        "term": "抽风",
        "category": "Ableism",
        "definition": "对癫痫发作症状的侮辱性描述，将病理现象简化为'发疯'，常用于比喻语境强化对癫痫的恐惧与嘲笑",
        "targets": "癫痫患者"
    },
    {
        "term": "唐氏",
        "category": "Ableism",
        "definition": "当用作简化标签或侮辱语时，将唐氏综合征患者的面部特征作为智力低下的视觉符号，用于网络骂战（如'你长得好唐'）构成严重冒犯",
        "targets": "唐氏综合征患者"
    }
]