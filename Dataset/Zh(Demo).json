    },
    {
        "term": "牛马",
        "category": "Classism",
        "definition": "网络热词，原指牛和马两种牲畜，网络上用于对现代打工人的调侃和称呼。",
        "targets": "打工人群体"
    },
    {
        "term": "凤凰男",
        "category": "Classism",
        "definition": "农村出身、通过努力进城，但隐含抠门、妈宝、拖累原生家庭的偏见，将阶层流动路径污名化为婚姻风险",
        "targets": "男性群体"
    },
    {
        "term": "搬砖的",
        "category": "Classism",
